.env
*.db
*.db-wal
*.db-shm
__pycache__/
*.pyc
.DS_Store
data/
# local Claude Code state (scheduled-task locks, session config) — never distribute
.claude/
# scratch drafts (issue replies etc.) — not for distribution
.drafts/
# certs/ are bundled in the image — tracked by git intentionally

# App certificate (provided by user at setup — see README / markoceri/leapmotor-certs)
certs/app.crt
certs/app.key
!certs/.gitkeep

# Personal one-off migration scripts + on-car reverse-engineering dev tools (not for distribution)
scripts/import_from_ha.py
scripts/import_ha_history.py
scripts/dump_raw_pids.py
scripts/send_climate.py
scripts/analyze_v2l.py
scripts/_replay_v2l_test.py

# Encryption key for stored credentials — MUST NEVER be committed
secret.key

# Dev-only compose override (bind-mounts source) — not for distribution
docker-compose.override.yml

# local trips-redesign backups (not for VCS)
web/templates/_backup_trips_*/
